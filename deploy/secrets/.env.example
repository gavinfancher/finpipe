# Example only. Real .env is generated by deploy/secrets/load_secrets.sh
# from GCP Secret Manager. Do not commit the generated .env.

POSTGRES_USER=finpipe
POSTGRES_PASSWORD=changeme
POSTGRES_DB=finpipe

JWT_SECRET=changeme
MASSIVE_API_KEY=changeme
CLOUDFLARED_TOKEN=eyJhIjoi...

GCP_PROJECT_ID=finpipe-prod
GCS_LAKEHOUSE_BUCKET=finpipe-lakehouse
GCS_DATA_BUCKET=finpipe-data
DATAPROC_REGION=us-central1
DATAPROC_SERVICE_ACCOUNT=finpipe-sa@finpipe-prod.iam.gserviceaccount.com

# Homelab only: path to the SA key on the host. Mounted into containers at
# /secrets/sa-key.json. Leave blank on the GCP VM (uses attached SA instead).
SA_KEY_PATH=
GOOGLE_APPLICATION_CREDENTIALS=
