# Reference for the variables compose.yml expects. The real .env is generated
# by deploy/host/load_secrets.sh from GCP Secret Manager — do not commit it,
# and do not put real secrets in this example file.

# --- pulled from Secret Manager (left blank here on purpose) ---
POSTGRES_PASSWORD=
DAGSTER_PG_PASSWORD=
JWT_SECRET=
BETA_KEY=
MASSIVE_API_KEY=
CLOUDFLARED_TOKEN=

# --- non-secret config ---
POSTGRES_USER=finpipe
POSTGRES_DB=finpipe

GCP_PROJECT_ID=finpipe-prod
GCS_LAKEHOUSE_BUCKET=finpipe-lakehouse
GCS_DATA_BUCKET=finpipe-data
DATAPROC_REGION=us-central1
DATAPROC_SERVICE_ACCOUNT=finpipe-sa@finpipe-prod.iam.gserviceaccount.com

# Homelab only: path to the SA key on the host. Mounted into containers at
# /secrets/sa-key.json. Leave blank on the GCP VM (uses attached SA instead).
SA_KEY_PATH=
GOOGLE_APPLICATION_CREDENTIALS=
